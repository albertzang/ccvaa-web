# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
# Agent QA Pass 1 live-run scratch (formal reports use docs/reports/QA-pass*.md)
docs/reports/.qa-pass1-*
scripts/qa-pass1-*.mjs

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Cursor local plan scratchpads (canonical product docs live under docs/)
.cursor/plans/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
