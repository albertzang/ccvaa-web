# Admin auth is the Hover webmail session inside /admin (same-origin /admin/mail proxy).
# No ADMIN_SESSION_SECRET, OTP, SMTP, or Redis/KV env vars are required for admin login.
#
# After merge of admin-console-0010, CEO may remove unused Vercel env if still present:
#   ADMIN_SESSION_SECRET, ADMIN_OTP_EMAIL, ADMIN_OTP_DEV_MODE,
#   SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, SMTP_FROM,
#   KV_REST_API_URL, KV_REST_API_TOKEN, KV_REST_API_READ_ONLY_TOKEN, KV_URL, REDIS_URL

# Vercel Preview Deployment Protection bypass
# Same value as Vercel → Settings → Deployment Protection → Protection Bypass for Automation
# Keep in .env.local only — never commit. QA/CEO uses it for Pass 1 Preview access.
# See docs/protocols/PREVIEW_PROTECTION.md
VERCEL_AUTOMATION_BYPASS_SECRET=
