# CCVAA Web — local env template
# Copy to `.env.local` (gitignored). Never commit secrets.

# Admin (`/admin`): auth is the Hover webmail session inside the mail iframe.
# App runtime does not read these — QA/CEO use them to sign into the mailbox when testing /admin.
# Never put these values in handoffs, reports, commits, or chat.
ADMIN_EMAIL=
ADMIN_PASS=

# Vercel Preview Deployment Protection bypass (QA Pass 1 / Preview)
# Same value as Vercel → Settings → Deployment Protection → Protection Bypass for Automation
# See docs/protocols/PREVIEW_PROTECTION.md
VERCEL_AUTOMATION_BYPASS_SECRET=

# --- Public feature switches (Vercel Edge Config) — members-0023+ ---

# One shared Edge Config store connected to all Vercel environments.
# Store three top-level items whose values are JSON objects:
# production = { "members": false }
# preview = { "members": false }
# development = { "members": false }
# The app selects the item with VERCEL_ENV; local/unset uses development.
EDGE_CONFIG=

# Flags are changed only in the Vercel Edge Config dashboard (or externally).
# Production is CEO/Admin-only. Agents may flip preview/development for testing
# and should restore them to Off afterward.

# --- Members platform (Neon + Drizzle) — members-0001+ ---

# Neon Postgres connection string (required for Members DB routes and migrate/seed scripts).
# Local Dev: Neon dev branch or local Postgres URL in `.env.local`.
# Vercel Preview / Production: set per environment in Vercel dashboard (CEO).
DATABASE_URL=

# --- Transactional email (Resend) — members-0002+ ---

# Resend API key (test key on Dev/Preview; live key on Production — CEO).
# Required to send OTP / newsletter confirm emails. Fail closed when missing.
RESEND_API_KEY=

# Verified sender for transactional mail, e.g. CCVAA <onboarding@resend.dev> (Resend test) or CEO live from-address.
RESEND_FROM_EMAIL=

# --- Member login session (members-0005+) ---

# HMAC secret for httpOnly `ccvaa_member_session` cookie (long random string).
# Required for login OTP verify. Does NOT grant `/admin` (Hover mailbox auth only).
# Fail closed when missing. Session TTL: 7 days — see src/lib/members/session-config.ts
MEMBER_SESSION_SECRET=

# --- Preview QA inbox (Mailosaur) — members-0002+ ---

# Optional on Dev/Preview for capturing OTP emails during QA. See docs/members/mailosaur-qa.md.
MAILOSAUR_API_KEY=
MAILOSAUR_SERVER_ID=

# --- ESP (email blasts + preference sync) — members-0003+ stub; hardened in members-0009 ---

# ESP API key and list/audience ID (CEO chooses provider). Stub sync until configured.
# ESP_API_KEY=
# ESP_LIST_ID=

# --- Stripe Join (Checkout) — members-0004+ (test mode on Dev/Preview; live in members-0009) ---

# Stripe secret key (sk_test_… on Dev/Preview). Required for Join Checkout. Fail closed when missing.
STRIPE_SECRET_KEY=

# Webhook signing secret (whsec_…). Point Stripe test webhook at:
#   POST https://<Preview-or-Dev-host>/api/members/webhooks/stripe
# Event: checkout.session.completed (minimum).
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (Dashboard → Products). Founding + Lifetime = one-time; Annual = recurring yearly.
STRIPE_PRICE_FOUNDING=
STRIPE_PRICE_LIFETIME=
STRIPE_PRICE_ANNUAL=

# Founding seat cap (active founding members). When full, Join offers Lifetime + Annual.
MEMBERSHIP_FOUNDING_CAP=

# Display fees in CAD cents. Lifetime must always be greater than Founding (validated at runtime).
MEMBERSHIP_FOUNDING_FEE_CENTS=
MEMBERSHIP_LIFETIME_FEE_CENTS=
MEMBERSHIP_ANNUAL_FEE_CENTS=
