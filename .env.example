# Admin session signing secret (min 32 characters)
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Where OTP codes are delivered
ADMIN_OTP_EMAIL=info@ccvaa.ca

# true = print OTP to server logs only (no email)
# false = send real email via Hover SMTP below
ADMIN_OTP_DEV_MODE=false

# Hover SMTP (official: mail.hover.com, port 465, SSL)
SMTP_HOST=mail.hover.com
SMTP_PORT=465
SMTP_USER=info@ccvaa.ca
SMTP_PASS=your-hover-mailbox-password
SMTP_FROM=info@ccvaa.ca

# Upstash Redis (required on Vercel Production + Preview for OTP verify across instances)
# Provision via Vercel Marketplace → Upstash Redis, or set manually.
# Local `next dev` may omit these (falls back to in-memory; single process only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
