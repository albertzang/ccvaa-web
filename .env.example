# Admin session signing secret (min 32 characters)
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Where OTP codes are delivered
ADMIN_OTP_EMAIL=info@ccvaa.ca

# true = print OTP to server logs only (no email)
# false = send real email via Hover SMTP below
ADMIN_OTP_DEV_MODE=false

# Hover SMTP (official: mail.hover.com, port 465, SSL)
SMTP_HOST=mail.hover.com
SMTP_PORT=465
SMTP_USER=info@ccvaa.ca
SMTP_PASS=your-hover-mailbox-password
SMTP_FROM=info@ccvaa.ca

# Upstash Redis via Vercel Marketplace (required on Production + Preview for OTP
# verify across serverless instances). Local `next dev` may omit these (in-memory).
# App runtime uses: KV_REST_API_URL + KV_REST_API_TOKEN
# Marketplace also provides (optional locally): KV_REST_API_READ_ONLY_TOKEN, KV_URL, REDIS_URL
KV_REST_API_READ_ONLY_TOKEN=
KV_REST_API_TOKEN=
KV_REST_API_URL=
KV_URL=
REDIS_URL=

# Vercel Preview Deployment Protection bypass
# Same value as Vercel → Settings → Deployment Protection → Protection Bypass for Automation
# Keep in .env.local only — never commit. QA uses it for Pass 1 Preview access.
# See docs/protocols/PREVIEW_PROTECTION.md
VERCEL_AUTOMATION_BYPASS_SECRET=